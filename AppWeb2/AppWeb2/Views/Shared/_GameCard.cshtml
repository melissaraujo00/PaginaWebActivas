@model AppWeb2.Models.VideoJuego

@{

    bool enPromocion = Model.EnDescuento
                       && Model.FechaInicioPromo.HasValue
                       && Model.FechaFinPromo.HasValue
                       && Model.FechaInicioPromo.Value.Date <= DateTime.Today
                       && Model.FechaFinPromo.Value.Date >= DateTime.Today;
}

<div class="col-md-6 col-lg-4 col-xl-3">
    <div class="card game-card h-100">

        <div class="badge-top">
            @if (enPromocion)
            {
                <span>Oferta</span>
            }
            else if (!string.IsNullOrEmpty(Model.EdadMinima))
            {
                <span>@Model.EdadMinima</span>
            }
            else
            {
                <span>+12</span>
            }
        </div>

        <div class="favorite">
            <i class="fa-regular fa-heart"></i>
        </div>


        <img src="@Model.imagen"
             class="card-img-top game-img"
             alt="@Model.Titulo" />

        <div class="card-body d-flex flex-column">


            <h5 class="card-title fw-bold">
                @Model.Titulo
            </h5>


            <div class="mt-2">
                @if (enPromocion && Model.PrecioDescuento.HasValue)
                {
                    <span class="text-muted text-decoration-line-through me-2">
                        $@Model.Precio.ToString("F2")
                    </span>
                    <span class="price text-danger fw-bold">
                        $@Model.PrecioDescuento.Value.ToString("F2")
                    </span>
                    
                }
                else
                {
                    <h4 class="price mt-2">
                        $@Model.Precio.ToString("F2")
                    </h4>
                }
            </div>


            <div class="d-flex align-items-center mt-auto pt-3">
                <i class="fa-solid fa-gamepad me-2 text-warning"></i>
                @if (Model.Categoria != null)
                {
                    <span class="text-muted small">@Model.Categoria.Nombre</span>
                }
                else
                {
                    <span class="text-muted small">Sin categoría</span>
                }
            </div>

        </div>
    </div>
</div>