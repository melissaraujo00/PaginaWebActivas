@model IEnumerable<AppWeb2.Models.Categoria>
@{
    ViewData["Title"] = "Categorías de Juegos";
}

<div class="container mt-5">
    <h2 class="text-center fw-bold mb-4" style="color: #FFD700;">Explora por Categoría</h2>

    <div class="row g-4">
        @foreach (var categoria in Model)
        {
            <div class="col-md-4 col-lg-3">
                <a asp-action="JuegosPorCategoria" asp-route-id="@categoria.id" class="text-decoration-none">
                    <div class="card category-card h-100 text-center">
                        <div class="card-body">
                            <i class="fas fa-gamepad fa-3x mb-3 text-warning"></i>
                            <h5 class="card-title fw-bold text-black">@categoria.Nombre</h5>
                            <p class="card-text text-muted">
                                @(categoria.VideoJuegos?.Count() ?? 0) juegos
                            </p>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            No hay categorías disponibles.
        </div>
    }
</div>