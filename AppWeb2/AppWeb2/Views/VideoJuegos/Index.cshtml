@model IEnumerable<AppWeb2.Models.VideoJuego>
@{
    ViewData["Title"] = "VideoJuegos";
}

<h2>Lista de Videojuegos</h2>

<a asp-action="Create" class="btn btn-primary mb-3">
    <i class="bi bi-plus-circle"></i> Nuevo Juego
</a>

<table class="table table-striped table-hover mt-3">
    <thead class="table-dark">
        <tr>
            <th>Título</th>
            <th>Descripción</th>
            <th>Categoría</th>
            <th>Edad Mín.</th>
            <th>Promoción</th>
            <th>Precio</th>
            <th>Fechas Promo</th>
            <th>Imagen</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var juego in Model)
        {
            bool enPromocion = juego.EnDescuento
            && juego.FechaInicioPromo.HasValue
            && juego.FechaFinPromo.HasValue
            && juego.FechaInicioPromo.Value.Date <= DateTime.Today
            && juego.FechaFinPromo.Value.Date >= DateTime.Today;

            <tr>
                <td>@juego.Titulo</td>
                <td>@(juego.Descripcion?.Length > 50 ? juego.Descripcion.Substring(0, 50) + "..." : juego.Descripcion)</td>
                <td>@(juego.Categoria?.Nombre ?? "Sin categoría")</td>
                <td>@juego.EdadMinima</td>
                <td>
                    @if (enPromocion)
                    {
                        <span class="badge bg-danger">Sí (activa)</span>
                    }
                    else if (juego.EnDescuento)
                    {
                        <span class="badge bg-warning text-dark">Sí (inactiva)</span>
                    }
                    else
                    {
                        <span class="badge bg-secondary">No</span>
                    }
                </td>
                <td>
                    @if (enPromocion && juego.PrecioDescuento.HasValue)
                    {
                        <span class="text-muted text-decoration-line-through me-1">$@juego.Precio.ToString("F2")</span>
                        <strong class="text-danger">$@juego.PrecioDescuento.Value.ToString("F2")</strong>
                    }
                    else
                    {
                        <strong>$@juego.Precio.ToString("F2")</strong>
                    }
                </td>
                <td>
                    @if (juego.FechaInicioPromo.HasValue && juego.FechaFinPromo.HasValue)
                    {
                        @($"{juego.FechaInicioPromo.Value:dd/MM/yyyy} - {juego.FechaFinPromo.Value:dd/MM/yyyy}")
                    }
                    else
                    {
                        <span class="text-muted">No definidas</span>
                    }
                </td>
                <td><img src="@juego.imagen" width="80" /></td>
                <td>
                    <a asp-action="Edit" asp-route-id="@juego.Id" class="btn btn-warning btn-sm">
                        Editar
                    </a>
                    <a asp-action="Delete" asp-route-id="@juego.Id" class="btn btn-danger btn-sm">
                        Eliminar
                    </a>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (!Model.Any())
{
    <div class="alert alert-info">
        No hay videojuegos registrados. ¡Crea uno nuevo!
    </div>
}